<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

	<changeSet id="001-create-master-schema" author="siletry">
		<sql>CREATE SCHEMA IF NOT EXISTS master;</sql>
	</changeSet>

	<changeSet id="002-create-tenant-table" author="siletry">
		<createTable tableName="tenant" schemaName="master">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="schema_name" type="VARCHAR(63)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="clinic_name" type="VARCHAR(255)">
				<constraints nullable="false" />
			</column>
			<column name="address" type="TEXT" />
			<column name="phone" type="VARCHAR(20)" />
			<column name="email" type="VARCHAR(255)" />
			<column name="subscription_tier" type="VARCHAR(20)"
				defaultValue="PHASE_1">
				<constraints nullable="false" />
			</column>
			<column name="status" type="VARCHAR(20)" defaultValue="TRIAL">
				<constraints nullable="false" />
			</column>
			<column name="trial_start_date" type="TIMESTAMP" />
			<column name="trial_end_date" type="TIMESTAMP" />
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
	</changeSet>

</databaseChangeLog>