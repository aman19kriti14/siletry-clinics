<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

	<changeSet id="t001-create-doctor" author="siletry">
		<createTable tableName="doctor">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="name" type="VARCHAR(255)">
				<constraints nullable="false" />
			</column>
			<column name="specialization" type="VARCHAR(255)" />
			<column name="slot_duration_minutes" type="INT"
				defaultValueNumeric="15">
				<constraints nullable="false" />
			</column>
			<column name="working_hours_json" type="TEXT" />
			<column name="active" type="BOOLEAN"
				defaultValueBoolean="true">
				<constraints nullable="false" />
			</column>
		</createTable>
	</changeSet>

	<changeSet id="t002-create-patient" author="siletry">
		<createTable tableName="patient">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="name" type="VARCHAR(255)">
				<constraints nullable="false" />
			</column>
			<column name="phone" type="VARCHAR(20)">
				<constraints nullable="false" />
			</column>
			<column name="email" type="VARCHAR(255)" />
			<column name="dob" type="DATE" />
			<column name="age" type="INT" />
			<column name="gender" type="VARCHAR(20)" />
			<column name="channel_preference" type="VARCHAR(20)"
				defaultValue="UNSET">
				<constraints nullable="false" />
			</column>
			<column name="created_via" type="VARCHAR(20)" />
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
		<createIndex indexName="idx_patient_phone"
			tableName="patient">
			<column name="phone" />
		</createIndex>
	</changeSet>

	<changeSet id="t003-create-appointment" author="siletry">
		<createTable tableName="appointment">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="patient_id" type="VARCHAR(36)">
				<constraints nullable="false"
					foreignKeyName="fk_appointment_patient" references="patient(id)" />
			</column>
			<column name="doctor_id" type="VARCHAR(36)">
				<constraints nullable="false"
					foreignKeyName="fk_appointment_doctor" references="doctor(id)" />
			</column>
			<column name="scheduled_at" type="TIMESTAMP">
				<constraints nullable="false" />
			</column>
			<column name="appointment_type" type="VARCHAR(20)" />
			<column name="status" type="VARCHAR(20)" defaultValue="BOOKED">
				<constraints nullable="false" />
			</column>
			<column name="booking_source" type="VARCHAR(20)" />
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
		<createIndex indexName="idx_appointment_scheduled_at"
			tableName="appointment">
			<column name="scheduled_at" />
		</createIndex>
		<createIndex indexName="idx_appointment_doctor_scheduled"
			tableName="appointment">
			<column name="doctor_id" />
			<column name="scheduled_at" />
		</createIndex>
	</changeSet>

	<changeSet id="t004-create-notification" author="siletry">
		<createTable tableName="notification">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="patient_id" type="VARCHAR(36)">
				<constraints nullable="false"
					foreignKeyName="fk_notification_patient" references="patient(id)" />
			</column>
			<column name="appointment_id" type="VARCHAR(36)">
				<constraints
					foreignKeyName="fk_notification_appointment"
					references="appointment(id)" />
			</column>
			<column name="intent" type="VARCHAR(30)">
				<constraints nullable="false" />
			</column>
			<column name="scheduled_for" type="TIMESTAMP">
				<constraints nullable="false" />
			</column>
			<column name="status" type="VARCHAR(20)"
				defaultValue="PENDING">
				<constraints nullable="false" />
			</column>
			<column name="channel_used" type="VARCHAR(20)" />
			<column name="payload" type="TEXT" />
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
			<column name="sent_at" type="TIMESTAMP" />
		</createTable>
		<!-- de-dupe fix from earlier: one reminder of a given intent per appointment -->
		<addUniqueConstraint tableName="notification"
			columnNames="appointment_id, intent"
			constraintName="uq_notification_appointment_intent" />
		<createIndex indexName="idx_notification_status_scheduled"
			tableName="notification">
			<column name="status" />
			<column name="scheduled_for" />
		</createIndex>
	</changeSet>

	<changeSet id="t005-create-staff-user" author="siletry">
		<createTable tableName="staff_user">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="email" type="VARCHAR(255)">
				<constraints nullable="false" unique="true" />
			</column>
			<column name="password_hash" type="VARCHAR(255)">
				<constraints nullable="false" />
			</column>
			<column name="name" type="VARCHAR(255)">
				<constraints nullable="false" />
			</column>
			<column name="role" type="VARCHAR(20)" defaultValue="STAFF">
				<constraints nullable="false" />
			</column>
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
	</changeSet>

	<changeSet id="t006-create-recall-rule" author="siletry">
		<createTable tableName="recall_rule">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="appointment_type" type="VARCHAR(20)">
				<constraints nullable="false" />
			</column>
			<column name="interval_days" type="INT">
				<constraints nullable="false" />
			</column>
			<column name="active" type="BOOLEAN"
				defaultValueBoolean="true">
				<constraints nullable="false" />
			</column>
			<column name="message_template" type="TEXT" />
		</createTable>
	</changeSet>

	<changeSet id="t007-create-feedback" author="siletry">
		<createTable tableName="feedback">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="patient_id" type="VARCHAR(36)">
				<constraints nullable="false"
					foreignKeyName="fk_feedback_patient" references="patient(id)" />
			</column>
			<column name="appointment_id" type="VARCHAR(36)">
				<constraints foreignKeyName="fk_feedback_appointment"
					references="appointment(id)" />
			</column>
			<column name="rating" type="INT">
				<constraints nullable="false" />
			</column>
			<column name="comment" type="TEXT" />
			<column name="sentiment" type="VARCHAR(20)" />
			<column name="escalated" type="BOOLEAN"
				defaultValueBoolean="false">
				<constraints nullable="false" />
			</column>
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
		<createIndex indexName="idx_feedback_escalated"
			tableName="feedback">
			<column name="escalated" />
		</createIndex>
	</changeSet>
	<changeSet id="t008-create-follow-up-response"
		author="siletry">
		<createTable tableName="follow_up_response">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="patient_id" type="VARCHAR(36)">
				<constraints nullable="false"
					foreignKeyName="fk_followup_patient" references="patient(id)" />
			</column>
			<column name="notification_id" type="VARCHAR(36)">
				<constraints foreignKeyName="fk_followup_notification"
					references="notification(id)" />
			</column>
			<column name="reply_text" type="TEXT">
				<constraints nullable="false" />
			</column>
			<column name="assessment" type="VARCHAR(20)" />
			<column name="ai_reasoning" type="TEXT" />
			<column name="escalated" type="BOOLEAN"
				defaultValueBoolean="false">
				<constraints nullable="false" />
			</column>
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
	</changeSet>
	<changeSet id="t009-create-queue-entry" author="siletry">
		<createTable tableName="queue_entry">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="appointment_id" type="VARCHAR(36)">
				<constraints nullable="false" unique="true"
					foreignKeyName="fk_queue_appointment" references="appointment(id)" />
			</column>
			<column name="token_number" type="INT">
				<constraints nullable="false" />
			</column>
			<column name="status" type="VARCHAR(20)"
				defaultValue="WAITING">
				<constraints nullable="false" />
			</column>
			<column name="checked_in_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
			<column name="called_at" type="TIMESTAMP" />
			<column name="completed_at" type="TIMESTAMP" />
		</createTable>
		<createIndex indexName="idx_queue_status"
			tableName="queue_entry">
			<column name="status" />
		</createIndex>
	</changeSet>
	<changeSet id="t010-create-location" author="siletry">
		<createTable tableName="location">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="name" type="VARCHAR(255)">
				<constraints nullable="false" />
			</column>
			<column name="address" type="TEXT" />
			<column name="phone" type="VARCHAR(20)" />
			<column name="active" type="BOOLEAN"
				defaultValueBoolean="true">
				<constraints nullable="false" />
			</column>
		</createTable>
	</changeSet>

	<changeSet id="t011-add-location-to-doctor" author="siletry">
		<addColumn tableName="doctor">
			<column name="location_id" type="VARCHAR(36)">
				<constraints foreignKeyName="fk_doctor_location"
					references="location(id)" />
			</column>
		</addColumn>
	</changeSet>

	<changeSet id="t012-add-location-to-staff-user"
		author="siletry">
		<addColumn tableName="staff_user">
			<!-- nullable: OWNER role sees all locations; STAFF can be scoped to one -->
			<column name="location_id" type="VARCHAR(36)">
				<constraints foreignKeyName="fk_staffuser_location"
					references="location(id)" />
			</column>
		</addColumn>
	</changeSet>
	<changeSet id="t013-create-conversation-message"
		author="siletry">
		<createTable tableName="conversation_message">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="patient_id" type="VARCHAR(36)">
				<constraints nullable="false"
					foreignKeyName="fk_conversation_patient" references="patient(id)" />
			</column>
			<column name="direction" type="VARCHAR(20)">
				<constraints nullable="false" />
			</column>
			<column name="content" type="TEXT">
				<constraints nullable="false" />
			</column>
			<column name="action_taken" type="TEXT" />
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
		</createTable>
		<createIndex indexName="idx_conversation_patient_created"
			tableName="conversation_message">
			<column name="patient_id" />
			<column name="created_at" />
		</createIndex>
	</changeSet>
	<changeSet id="t014-add-conversation-mode-to-patient"
		author="siletry">
		<addColumn tableName="patient">
			<column name="conversation_mode" type="VARCHAR(20)"
				defaultValue="AI">
				<constraints nullable="false" />
			</column>
		</addColumn>
	</changeSet>

	<changeSet id="t015-create-escalation" author="siletry">
		<createTable tableName="escalation">
			<column name="id" type="VARCHAR(36)">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="patient_id" type="VARCHAR(36)">
				<constraints nullable="false"
					foreignKeyName="fk_escalation_patient" references="patient(id)" />
			</column>
			<column name="reason" type="VARCHAR(30)">
				<constraints nullable="false" />
			</column>
			<column name="detail" type="TEXT" />
			<column name="resolved" type="BOOLEAN"
				defaultValueBoolean="false">
				<constraints nullable="false" />
			</column>
			<column name="created_at" type="TIMESTAMP"
				defaultValueComputed="CURRENT_TIMESTAMP">
				<constraints nullable="false" />
			</column>
			<column name="resolved_at" type="TIMESTAMP" />
		</createTable>
		<createIndex indexName="idx_escalation_resolved"
			tableName="escalation">
			<column name="resolved" />
		</createIndex>
	</changeSet>
	<changeSet id="t016-add-phone-to-staff-user" author="siletry">
		<addColumn tableName="staff_user">
			<column name="phone" type="VARCHAR(20)" />
		</addColumn>
	</changeSet>

</databaseChangeLog>